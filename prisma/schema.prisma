generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Charity {
  id                String   @id @default(uuid())
  name              String   @unique
  establishmentDate String?
  licenseNumber     String?
  logoUrl           String?
  domain            String?
  createdAt         DateTime @default(now())
  programs          Program[]

  // Financial fields
  contractValue     Float    @default(0)
  paidAmount        Float    @default(0)
  grants            Float    @default(0)
  financialLogs     FinancialLog[]
}

model FinancialLog {
  id          String   @id @default(uuid())
  charityId   String
  charity     Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  type        String   // "CONTRACT_UPDATE" | "PAID_UPDATE" | "ADD_GRANT" | "DISBURSEMENT"
  amount      Float
  notes       String?
  createdAt   DateTime @default(now())
}

model Program {
  id            String   @id @default(uuid())
  name          String
  beneficiaries Int
  charityId     String
  charity       Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SurveyResponse {
  id              String   @id @default(uuid())
  charityName     String
  establishmentDate String
  licenseNumber   String
  authorizedName  String
  authorizedTitle String
  scorePercentage Int
  answers         Json
  createdAt       DateTime @default(now())
}

model HexagonalResponse {
  id              String   @id @default(uuid())
  charityName     String
  authorizedTitle String
  answers         Json
  createdAt       DateTime @default(now())
}

model PerformanceMetric {
  id              String   @id @default(uuid())
  charityName     String
  year            Int
  data            Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([charityName, year])
}

enum Role {
  ADMIN
  EMPLOYEE
  EXECUTIVE_DIRECTOR
  GENERAL_MANAGER
  ADMINISTRATIVE_SECRETARIAT
  STRATEGY
  FINANCE
}

model Employee {
  id                   String        @id @default(uuid())
  name                 String
  phone                String        @unique
  password             String
  avatarUrl            String?
  role                 Role          @default(EMPLOYEE)
  permissions          String[]
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  assignedTasks        Task[]        @relation("AssignedTasks")
  createdTasks         Task[]        @relation("CreatedTasks")
  employeeAchievements Achievement[] @relation("EmployeeAchievements")
  createdAchievements  Achievement[] @relation("CreatedAchievements")
}

model Task {
  id           String    @id @default(uuid())
  title        String
  assignedToId String
  assignedTo   Employee  @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    Employee  @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)
  charityId    String?
  charityName  String?
  isInternal   Boolean   @default(false)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  proofUrl     String?
  proofPublicId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  employeeId  String
  employee    Employee @relation("EmployeeAchievements", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   Employee @relation("CreatedAchievements", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model News {
  id          String   @id @default(uuid())
  charityName String
  category    String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SurveyLink {
  id          String   @id @default(uuid())
  charityName String
  surveyType  String   // "READINESS" or "HEXAGONAL"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}