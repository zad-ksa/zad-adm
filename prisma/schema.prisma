generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Charity {
  id                String   @id @default(uuid())
  name              String   @unique
  establishmentDate String?
  licenseNumber     String?
  logoUrl           String?
  domain            String?
  createdAt         DateTime @default(now())
  programs          Program[]

  // Financial fields
  contractValue     Float    @default(0)
  paidAmount        Float    @default(0)
  grants            Float    @default(0)
  financialLogs     FinancialLog[]
  meetings          Meeting[]
  strategicStage    Int      @default(1)
  strategicStages  StrategicStage[]
  governanceStages GovernanceStage[]
  financeStages    FinanceStage[]
  
  // Timeline Configurations
  strategyTimelineName String? @default("التخطيط الاستراتيجي")
  strategyTimelineDept String? @default("STRATEGY")
  
  governanceTimelineName String? @default("الحوكمة")
  governanceTimelineDept String? @default("GOVERNANCE")
  
  financeTimelineName String? @default("تنمية الموارد المالية")
  financeTimelineDept String? @default("FINANCE")

  regulationVisibilities CharityRegulationVisibility[]
  employees         Employee[]
  isReadinessVisible Boolean @default(false)
  isPerformanceEditable Boolean @default(false)
  services          Service[]
}

model StrategicStage {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  duration    String?
  order       Int      @default(0)
  isCurrent   Boolean  @default(false)
  isContinuous Boolean @default(false)
  isActive    Boolean  @default(true)
  charityId   String
  charity     Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GovernanceStage {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  duration    String?
  order       Int      @default(0)
  isCurrent   Boolean  @default(false)
  isContinuous Boolean @default(false)
  isActive    Boolean  @default(true)
  charityId   String
  charity     Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinanceStage {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  duration    String?
  order       Int      @default(0)
  isCurrent   Boolean  @default(false)
  isContinuous Boolean @default(false)
  isActive    Boolean  @default(true)
  charityId   String
  charity     Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Meeting {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  charityId   String
  charity     Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FinancialLog {
  id          String   @id @default(uuid())
  charityId   String
  charity     Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  type        String   // "CONTRACT_UPDATE" | "PAID_UPDATE" | "ADD_GRANT" | "DISBURSEMENT"
  amount      Float
  notes       String?
  createdAt   DateTime @default(now())
}

model Program {
  id            String   @id @default(uuid())
  name          String
  beneficiaries Int
  charityId     String
  charity       Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SurveyResponse {
  id              String   @id @default(uuid())
  charityName     String
  establishmentDate String
  licenseNumber   String
  authorizedName  String
  authorizedTitle String
  scorePercentage Int
  answers         Json
  createdAt       DateTime @default(now())
}

model HexagonalResponse {
  id              String   @id @default(uuid())
  charityName     String
  authorizedTitle String
  answers         Json
  createdAt       DateTime @default(now())
}

model PerformanceMetric {
  id              String   @id @default(uuid())
  charityName     String
  year            Int
  data            Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([charityName, year])
}

enum Role {
  ADMIN
  EXECUTIVE_DIRECTOR
  GENERAL_MANAGER
  ADMINISTRATIVE_SECRETARIAT
  STRATEGY
  FINANCE
  CHARITY_CLIENT
}

model Employee {
  id                   String        @id @default(uuid())
  name                 String
  phone                String        @unique
  password             String
  avatarUrl            String?
  role                 Role          @default(STRATEGY)
  charityId            String?       // For CHARITY_CLIENT accounts
  charity              Charity?      @relation(fields: [charityId], references: [id])
  permissions          String[]
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  assignedTasks        Task[]        @relation("AssignedTasks")
  createdTasks         Task[]        @relation("CreatedTasks")
  employeeAchievements Achievement[] @relation("EmployeeAchievements")
  createdAchievements  Achievement[] @relation("CreatedAchievements")
}

model Task {
  id           String    @id @default(uuid())
  title        String
  assignedToId String
  assignedTo   Employee  @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    Employee  @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)
  charityId    String?
  charityName  String?
  isInternal   Boolean   @default(false)
  isCompleted  Boolean   @default(false)
  status       String    @default("NOT_STARTED") // "NOT_STARTED", "IN_PROGRESS", "COMPLETED"
  priority     Int       @default(3) // 1: High, 2: Medium, 3: Low
  completedAt  DateTime?
  proofUrl     String?
  proofPublicId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([assignedToId, isCompleted])
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  employeeId  String
  employee    Employee @relation("EmployeeAchievements", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     Employee @relation("CreatedAchievements", fields: [createdById], references: [id], onDelete: Cascade)
  charityId     String?
  charityName   String?
  isInternal    Boolean  @default(false)
  proofUrl      String?
  proofPublicId String?
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
}

model News {
  id          String   @id @default(uuid())
  charityName String
  category    String
  title       String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([charityName])
}

model SurveyLink {
  id          String   @id @default(uuid())
  charityName String
  surveyType  String   // "READINESS" or "HEXAGONAL"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Regulation {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String   // "الإشراف والحوكمة" or "التحول الرقمي" or "القطاع غير الربحي"
  link        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  charityVisibilities CharityRegulationVisibility[]
}

model CharityRegulationVisibility {
  id           String     @id @default(uuid())
  charityId    String
  regulationId String
  isVisible    Boolean    @default(true)
  charity      Charity    @relation(fields: [charityId], references: [id], onDelete: Cascade)
  regulation   Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)

  @@unique([charityId, regulationId])
}

model Service {
  id          String   @id @default(uuid())
  name        String
  department  String?  // 'STRATEGY', 'GOVERNANCE', 'FINANCE', 'PROGRAMS', 'HR' or null
  charityId   String
  charity     Charity  @relation(fields: [charityId], references: [id], onDelete: Cascade)
  stages      ServiceStage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceStage {
  id          String   @id @default(uuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  order       Int      @default(0)
  isCurrent   Boolean  @default(false)
  isContinuous Boolean @default(false)
  isActive    Boolean  @default(true)
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}