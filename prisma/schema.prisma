generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Charity {
  id                String   @id @default(uuid())
  name              String   @unique
  establishmentDate String?
  licenseNumber     String?
  logoUrl           String?
  createdAt         DateTime @default(now())
}

model SurveyResponse {
  id              String   @id @default(uuid())
  charityName     String
  establishmentDate String
  licenseNumber   String
  authorizedName  String
  authorizedTitle String
  scorePercentage Int
  answers         Json
  createdAt       DateTime @default(now())
}

model HexagonalResponse {
  id              String   @id @default(uuid())
  charityName     String
  authorizedTitle String
  answers         Json
  createdAt       DateTime @default(now())
}

model PerformanceMetric {
  id              String   @id @default(uuid())
  charityName     String
  year            Int
  data            Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([charityName, year])
}

enum Role {
  ADMIN
  EMPLOYEE
}

model Employee {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  password    String
  role        Role     @default(EMPLOYEE)
  permissions String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
